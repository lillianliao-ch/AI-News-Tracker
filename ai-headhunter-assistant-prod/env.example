# ========================================
# AI 猎头助手 - 后台服务环境变量配置
# ========================================
# 复制此文件为 backend/.env 并填入真实的配置信息
# cp env.example backend/.env

# ========================================
# 基础配置
# ========================================
ENV=development  # development | production
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# ========================================
# 数据库配置
# ========================================
# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/headhunter_db

# Redis
REDIS_URL=redis://localhost:6379/0

# ========================================
# OpenAI 配置
# ========================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o  # gpt-4o | gpt-4o-mini
OPENAI_API_BASE=https://api.openai.com/v1  # 如使用代理可修改

# ========================================
# Claude 配置（可选）
# ========================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ========================================
# 飞书配置
# ========================================
# 飞书应用凭证（在飞书开放平台创建应用后获取）
FEISHU_APP_ID=cli_a99c635ace69501c4
FEISHU_APP_SECRET=YJQRDIZyRtHfPkCbdT3BTdkLDjVT62Cw

# 飞书多维表格配置
# 从飞书多维表格 URL 提取: https://xxx.feishu.cn/wiki/{APP_TOKEN}?table={TABLE_ID}
FEISHU_APP_TOKEN=XMqKwc0WCimjkIkK4fMcEtflnWd  # 从 URL 中的 wiki/ 后面提取
FEISHU_TABLE_ID=tblQx2BAJqTAgHQA              # 从 URL 参数 table= 后面提取

# 飞书 Webhook（用于告警通知）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# Boss 直聘配置
# ========================================
# 支持配置多个账号（JSON 格式）
BOSS_ACCOUNTS='[
    {
        "phone": "138****1234",
        "password": "your_password",
        "daily_limit": 100
    }
]'

# ========================================
# OCR 配置（可选，用于处理图片简历）
# ========================================
# 腾讯云 OCR
TENCENT_SECRET_ID=AKIDxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TENCENT_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# 对象存储配置（用于存储简历文件）
# ========================================
# 阿里云 OSS
OSS_ACCESS_KEY_ID=LTAI5xxxxxxxxxxxxxxxx
OSS_ACCESS_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OSS_BUCKET_NAME=headhunter-resumes
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com

# ========================================
# 任务队列配置
# ========================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ========================================
# 日志配置
# ========================================
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
LOG_FILE_PATH=logs/app.log

# ========================================
# 限流配置
# ========================================
# 打招呼限流
GREETING_DAILY_LIMIT=100          # 每日发送上限
GREETING_INTERVAL_MIN=30          # 发送间隔（秒）最小值
GREETING_INTERVAL_MAX=90          # 发送间隔（秒）最大值
GREETING_TIME_WINDOW_START=09:00  # 发送时间窗口开始
GREETING_TIME_WINDOW_END=21:00    # 发送时间窗口结束

# 候选人处理限流
PROCESSING_DELAY_MIN=5            # 处理间隔（秒）最小值
PROCESSING_DELAY_MAX=10           # 处理间隔（秒）最大值

# ========================================
# AI 评估配置
# ========================================
# 匹配度权重配置
MATCH_WEIGHT_SKILL=0.40           # 技能匹配度权重
MATCH_WEIGHT_EXPERIENCE=0.30      # 经验匹配度权重
MATCH_WEIGHT_EDUCATION=0.15       # 教育背景权重
MATCH_WEIGHT_STABILITY=0.15       # 稳定性权重

# 推荐等级阈值
RECOMMEND_THRESHOLD_HIGH=75       # "推荐"等级阈值
RECOMMEND_THRESHOLD_MEDIUM=60     # "一般"等级阈值

# ========================================
# 安全配置
# ========================================
# API Token（用于 Chrome 插件认证）
API_SECRET_KEY=your-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440  # 24小时

# CORS 配置
CORS_ORIGINS=["http://localhost:3000", "chrome-extension://*"]

# ========================================
# 功能开关
# ========================================
ENABLE_AUTO_GREETING=true         # 是否启用自动打招呼
ENABLE_OCR_FALLBACK=true          # 是否启用 OCR 兜底
ENABLE_DUPLICATE_CHECK=true       # 是否启用去重检查
ENABLE_HUMAN_REVIEW=false         # 是否启用人工审核模式

# ========================================
# 性能配置
# ========================================
MAX_WORKERS=4                     # 最大并发处理数
REQUEST_TIMEOUT=30                # API 请求超时时间（秒）
DATABASE_POOL_SIZE=10             # 数据库连接池大小
REDIS_MAX_CONNECTIONS=50          # Redis 最大连接数

