{
  "manifest_version": 3,
  "name": "AI猎头助手",
  "version": "1.0.3",
  "description": "自动筛选简历，AI评估候选人匹配度",
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:18001/*",
    "http://localhost:18002/*",
    "https://www.zhipin.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.zhipin.com/*"
      ],
      "js": [
        "content-full.js"
      ],
      "all_frames": false
    }
  ]
}