# AI News Tracker 环境变量配置示例

# ==================== API Keys ====================
# OpenAI API Key（用于分类和内容生成）
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API Key（用于摘要和内容生成）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== Database ====================
# 数据库连接字符串
DATABASE_URL=sqlite+aiosqlite:///./data/ai_news.db

# ==================== Cache ====================
# 是否启用缓存
ENABLE_CACHE=true
# 缓存过期时间（秒）
CACHE_TTL=1800

# ==================== Crawler ====================
# 爬取间隔（秒）- 默认2小时
CRAWL_INTERVAL=7200
# 最小请求间隔（秒）
MIN_REQUEST_INTERVAL=2.0
# 最大重试次数
MAX_RETRIES=3

# ==================== AI Models ====================
# 分类模型
CLASSIFY_MODEL=gpt-4o-mini
# 摘要模型
SUMMARY_MODEL=claude-3-5-sonnet-20241022
# 生成模型
GENERATE_MODEL=claude-3-5-sonnet-20241022

# ==================== Logging ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# 日志文件
LOG_FILE=ai_news_tracker.log

# ==================== Application ====================
# 应用端口
PORT=8000
# 前端地址
FRONTEND_URL=http://localhost:4321
# 是否启用调试模式
DEBUG=false
