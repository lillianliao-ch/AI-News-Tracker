# ============================================================
# AI News Tracker - 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# ============================================================

# ==================== OpenAI API配置 ====================
# 使用千问API
OPENAI_API_KEY=sk-4e2bb9108e1541f9b7dd88855922c7a3
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==================== AI模型配置 ====================
CLASSIFY_MODEL=qwen-max
SUMMARY_MODEL=qwen-plus
GENERATE_MODEL=qwen-max

# ==================== 数据库配置 ====================
# Railway会自动提供DATABASE_URL
# 本地开发使用SQLite
DATABASE_URL=sqlite:///./data/ai_news.db

# ==================== Docker Compose配置 ====================
# 如果使用docker-compose，配置PostgreSQL
POSTGRES_PASSWORD=ainews123
POSTGRES_DB=ainews
POSTGRES_USER=postgres

# ==================== 服务配置 ====================
LOG_LEVEL=INFO
DEBUG=false
PORT=8000

# ==================== 爬虫配置 ====================
CRAWL_INTERVAL=7200
MIN_REQUEST_INTERVAL=2.0
MAX_RETRIES=3

# ==================== 缓存配置 ====================
ENABLE_CACHE=true
CACHE_TTL=1800
