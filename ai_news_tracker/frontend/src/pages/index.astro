---
// src/pages/index.astro - 主页（参考 newsnow 的布局）
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import NewsGrid from '../components/NewsGrid.astro';
import RefreshButton from '../components/RefreshButton.astro';

// 从 API 获取资讯
let allNews = [];
try {
  // SSR uses internal docker/host network
  const API_BASE = import.meta.env.VITE_API_BASE_URL || 'http://localhost:8002/api';
  console.log(`[SSR] Fetching news from ${API_BASE}...`);
  const response = await fetch(`${API_BASE}/news?limit=50`);
  const data = await response.json();
  if (Array.isArray(data)) {
    allNews = data;
  } else {
    console.error('[SSR] API returned non-array:', data);
  }
} catch (error) {
  console.error('[SSR] 获取资讯失败:', error);
}

// 分类
const categories = ['全部', '产品', '模型', '融资', '观点'];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="AI News Tracker - 优雅的AI资讯阅读平台" />
    <title>AI News Tracker - AI资讯追踪与内容生成</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  </head>
  <body>
    <div class="container">
      <!-- 侧边栏 -->
      <Sidebar />

      <!-- 主内容区 -->
      <main class="main-content">
        <!-- 头部 -->
        <Header />

        <!-- 操作栏 -->
        <div class="action-bar">
          <div class="categories">
            {categories.map((cat, index) => (
              <button class={`category-btn ${index === 0 ? 'active' : ''}`} data-category={cat}>
                {cat}
              </button>
            ))}
          </div>

          <RefreshButton />
        </div>

        <!-- 资讯网格 -->
        <NewsGrid news={allNews} />

        <!-- 加载更多 -->
        <div class="load-more">
          <button id="loadMoreBtn">加载更多</button>
        </div>
      </main>
    </div>

    <!-- Pass PUBLIC_API_URL to client via data attribute on a script or meta -->
    <script define:vars={{ PUBLIC_API_URL: import.meta.env.PUBLIC_API_URL || 'http://localhost:8002' }}>
        window.PUBLIC_API_URL = PUBLIC_API_URL;
    </script>

    <script is:inline>
      // ✨ AI分类映射（将前端标签映射到AI分类）
      const AI_CATEGORY_MAP = {
        '全部': null,
        '产品': 'product',
        '模型': 'model',
        '融资': 'investment',
        '观点': 'view'
      };

      // Helper to get API URL
      const getApiUrl = (path) => {
        const baseUrl = window.PUBLIC_API_URL || 'http://localhost:8002';
        // Remove trailing slash from base if present
        const cleanBase = baseUrl.replace(/\/$/, '');
        // Ensure path starts with /api if not present in base (logic depends on how we set env var)
        // In deploy script: PUBLIC_API_URL="http://$SERVER_IP:8002" (root)
        // So we append /api
        return `${cleanBase}/api${path}`;
      };

      // 加载统计信息并更新分类按钮
      async function loadStatsAndUpdateCategories() {
        try {
          const response = await fetch(getApiUrl('/stats'));
          const stats = await response.json();

          // ✨ 使用AI分类统计
          document.querySelectorAll('.category-btn').forEach(btn => {
            const category = btn.dataset.category;
            const aiCategory = AI_CATEGORY_MAP[category];

            let count;
            if (category === '全部') {
              count = stats.total_news || 0;
            } else {
              count = stats.ai_category_stats?.[aiCategory] || 0;
            }
            btn.textContent = `${category} (${count})`;
          });
        } catch (error) {
          console.error('加载统计失败:', error);
        }
      }

      // 页面加载时获取统计
      loadStatsAndUpdateCategories();

      // 分类筛选
      document.querySelectorAll('.category-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const category = e.target.dataset.category;

          // 更新活动状态
          document.querySelectorAll('.category-btn').forEach(b => b.classList.remove('active'));
          e.target.classList.add('active');

          // ✨ 使用AI分类筛选
          const aiCategory = AI_CATEGORY_MAP[category];
          
          let url = getApiUrl('/news?limit=50');
          if (aiCategory) {
             url = getApiUrl(`/news?ai_category=${aiCategory}&limit=50`);
          }

          const response = await fetch(url);
          const news = await response.json();

          // 更新显示（触发自定义事件）
          window.dispatchEvent(new CustomEvent('news-updated', { detail: news }));
        });
      });

      // 加载更多
      document.getElementById('loadMoreBtn')?.addEventListener('click', async () => {
        const currentCount = document.querySelectorAll('.news-card').length;
        const response = await fetch(getApiUrl(`/news?offset=${currentCount}&limit=20`));
        const news = await response.json();

        // 触发更新事件
        window.dispatchEvent(new CustomEvent('news-appended', { detail: news }));
      });
    </script>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen',
      'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue',
      sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    background: #f5f7fa;
    color: #1a1a1a;
  }

  .container {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 24px;
    max-width: 1400px;
    margin: 0 auto;
    padding: 24px;
    min-height: 100vh;
  }

  @media (max-width: 768px) {
    .container {
      grid-template-columns: 1fr;
      padding: 16px;
    }
  }

  .main-content {
    min-width: 0;
  }

  .action-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    gap: 16px;
  }

  .categories {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .category-btn {
    padding: 8px 20px;
    border: 1px solid #e0e0e0;
    background: white;
    border-radius: 20px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    color: #666;
    transition: all 0.2s ease;
  }

  .category-btn:hover {
    border-color: #007bff;
    color: #007bff;
  }

  .category-btn.active {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-color: transparent;
  }

  .load-more {
    text-align: center;
    margin-top: 40px;
  }

  .load-more button {
    padding: 12px 32px;
    background: white;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    cursor: pointer;
    font-size: 16px;
    font-weight: 500;
    color: #666;
    transition: all 0.2s ease;
  }

  .load-more button:hover {
    border-color: #667eea;
    color: #667eea;
  }
</style>
