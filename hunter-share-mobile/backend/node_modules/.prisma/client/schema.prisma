// 移动端专用数据库Schema - 精简版
// 从主平台的 schema.prisma 提取出移动端需要的核心表
// 
// 使用方式：
// 1. 将此文件复制到新项目的 prisma/schema.prisma
// 2. 运行 npx prisma generate
// 3. 运行 npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 枚举类型 ====================

// 用户角色
enum UserRole {
  platform_admin // 平台管理员
  company_admin // 公司管理员
  consultant // 猎头顾问
  soho // SOHO猎头
}

// 用户状态
enum UserStatus {
  registered // 已注册（待审核）
  verified // 已认证（可发布信息）
  active // 活跃
  suspended // 已暂停
}

// 信息类型
enum PostType {
  job_seeking // 找人才
  talent_recommendation // 推人才
}

// 信息状态
enum PostStatus {
  pending // 待审核
  approved // 已通过
  rejected // 已拒绝
}

// 通知类型
enum NotificationType {
  system // 系统通知
  user_approved // 用户审核通过
  user_rejected // 用户审核拒绝
  post_approved // 信息审核通过
  post_rejected // 信息审核拒绝
  new_post // 新信息发布
  post_reply // 信息回复
}

// ==================== 核心表 ====================

// 用户表
model User {
  id       String @id @default(uuid())
  username String @db.VarChar(50)
  email    String @unique @db.VarChar(100)
  phone    String @unique @db.VarChar(20)
  password String @db.VarChar(255)

  // 角色和状态
  role   UserRole   @default(soho)
  status UserStatus @default(registered)

  // 可选信息
  wechatId String? @map("wechat_id") @db.VarChar(50)
  bio      String? @db.Text
  avatar   String? @db.VarChar(500)

  // 统计信息
  postsCount    Int @default(0) @map("posts_count")
  approvedPosts Int @default(0) @map("approved_posts")
  totalViews    Int @default(0) @map("total_views")

  // 时间戳
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz

  // 关系
  hunterPosts   HunterPost[]
  notifications Notification[]
  shareLinks    ShareLink[]
  shareTracking ShareTracking[]

  @@index([phone])
  @@index([email])
  @@index([role, status])
  @@map("users")
}

// 猎头信息发布表
model HunterPost {
  id      String   @id @default(uuid())
  type    PostType // 信息类型
  title   String   @db.VarChar(100)
  content String   @db.Text

  // 状态和优先级
  status  PostStatus @default(approved)
  urgency Int        @default(0) // 紧急程度（0-5，越高越紧急）

  // 统计信息
  viewCount  Int @default(0) @map("view_count")
  replyCount Int @default(0) @map("reply_count")
  shareCount Int @default(0) @map("share_count")

  // 发布者信息
  publisherId String @map("publisher_id")
  publisher   User   @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  // 审核信息
  reviewedAt      DateTime? @map("reviewed_at") @db.Timestamptz
  reviewedBy      String?   @map("reviewed_by")
  rejectionReason String?   @map("rejection_reason") @db.Text

  // 时间戳
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  expiresAt DateTime? @map("expires_at") @db.Timestamptz // 过期时间

  @@index([publisherId])
  @@index([type, status])
  @@index([createdAt])
  @@index([status, urgency])
  @@map("hunter_posts")
}

// 通知表
model Notification {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String           @db.VarChar(100)
  content String           @db.Text

  // 关联信息
  relatedId   String? @map("related_id") // 关联的信息ID（如帖子ID、用户ID等）
  relatedType String? @map("related_type") @db.VarChar(50) // 关联类型

  // 状态
  isRead Boolean   @default(false) @map("is_read")
  readAt DateTime? @map("read_at") @db.Timestamptz

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ==================== 分享追踪表（可选）====================

// 分享链接表
model ShareLink {
  id        String @id @default(uuid())
  shortCode String @unique @map("short_code") @db.VarChar(10) // 短链接代码

  // 分享信息
  jobId        String? @map("job_id") // 职位ID（如果分享的是职位）
  postId       String? @map("post_id") // 帖子ID（如果分享的是帖子）
  consultantId String  @map("consultant_id") // 分享者ID
  consultant   User    @relation(fields: [consultantId], references: [id], onDelete: Cascade)

  // 统计信息
  viewCount     Int @default(0) @map("view_count")
  clickCount    Int @default(0) @map("click_count")
  registerCount Int @default(0) @map("register_count")

  // 时间戳
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  expiresAt DateTime? @map("expires_at") @db.Timestamptz

  // 关系
  tracking ShareTracking[]

  @@index([shortCode])
  @@index([consultantId])
  @@map("share_links")
}

// 分享追踪记录表
model ShareTracking {
  id String @id @default(uuid())

  // 分享链接
  linkId String    @map("link_id")
  link   ShareLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  // 访问者信息
  userId String? @map("user_id") // 如果用户已登录
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // 行为追踪
  action    String  @db.VarChar(20) // view, click, register
  source    String? @db.VarChar(50) // 来源（如 wechat, qq, direct）
  userAgent String? @map("user_agent") @db.Text
  ipAddress String? @map("ip_address") @db.VarChar(50)

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([linkId, action])
  @@index([userId])
  @@index([createdAt])
  @@map("share_tracking")
}

// ==================== 辅助表（可选）====================

// 群组表（如果需要实现真实的群组功能）
model Group {
  id          String  @id @default(uuid())
  name        String  @db.VarChar(100)
  description String? @db.Text
  industry    String? @db.VarChar(50) // 行业分类

  // 状态
  isActive Boolean @default(true) @map("is_active")

  // 统计
  memberCount Int @default(0) @map("member_count")
  postCount   Int @default(0) @map("post_count")

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // 关系
  members GroupMember[]

  @@index([industry])
  @@map("groups")
}

// 群组成员表
model GroupMember {
  id String @id @default(uuid())

  groupId String @map("group_id")
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  // user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 角色
  role String @default("member") @db.VarChar(20) // owner, admin, member

  // 时间戳
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz

  @@unique([groupId, userId])
  @@index([userId])
  @@map("group_members")
}

// ==================== 使用说明 ====================

// 1. 环境变量配置（.env文件）
// DATABASE_URL="postgresql://username:password@localhost:5432/hunter_share_mobile?schema=public"
// JWT_SECRET="your-super-secret-jwt-key-change-in-production"

// 2. 初始化数据库
// npx prisma generate
// npx prisma migrate dev --name init

// 3. 查看数据库
// npx prisma studio

