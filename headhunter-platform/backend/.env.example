# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/headhunter_platform"

# Redis Configuration
REDIS_URL="redis://localhost:6379"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Server Configuration
PORT=4000
HOST=localhost
NODE_ENV=development
LOG_LEVEL=info

# File Upload Configuration
MAX_FILE_SIZE=50485760  # 50MB in bytes
UPLOAD_DIRECTORY="uploads"

# Multi-Engine OCR Configuration
# Aliyun OCR (optional, for enhanced accuracy)
ALIYUN_OCR_ACCESS_KEY=""
ALIYUN_OCR_SECRET=""
ALIYUN_OCR_ENDPOINT=""

# Baidu OCR (optional, for enhanced accuracy)
BAIDU_OCR_API_KEY=""
BAIDU_OCR_SECRET_KEY=""

# OCR Enhancement Settings
OCR_ENABLE_PREPROCESSING=true
OCR_ENABLE_NLP=true
OCR_CONFIDENCE_THRESHOLD=0.6

# WeChat Integration
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""

# Email/SMS Services
EMAIL_SERVICE_API_KEY=""
SMS_SERVICE_API_KEY=""

# Object Storage Service (Alibaba Cloud OSS)
OSS_REGION="oss-cn-hangzhou"
OSS_BUCKET=""
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
OSS_ENDPOINT=""

# Monitoring & Logging
SENTRY_DSN=""