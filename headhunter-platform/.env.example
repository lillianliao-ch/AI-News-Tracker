# Global Environment Configuration
# Copy this file to .env and adjust the values as needed

# Development Environment
NODE_ENV=development

# Database Configuration (for Docker setup)
POSTGRES_DB=headhunter_platform
POSTGRES_USER=headhunter_user
POSTGRES_PASSWORD=headhunter_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis Configuration (for Docker setup)
REDIS_PASSWORD=headhunter_redis_pass
REDIS_HOST=localhost
REDIS_PORT=6379

# Application URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# JWT Configuration
JWT_SECRET=headhunter-jwt-secret-key-change-in-production

# Docker Configuration
COMPOSE_PROJECT_NAME=headhunter-platform

# Logging Level
LOG_LEVEL=info